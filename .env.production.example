# Base de datos PostgreSQL dentro de Docker Compose
DATABASE_URL=postgresql://postgres:change-me-db-password@db:5432/f2p_catalog

# Producción
SECRET_KEY=change-me-to-a-long-random-secret-key
FLASK_ENV=production
FREETOGAME_API_URL=https://www.freetogame.com/api

# Credenciales del usuario administrador inicial
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Usuario especial de demo (sin valor por defecto de contraseña)
CALAYA_EMAIL=pablo_laya92@hotmail.com
CALAYA_PASSWORD=

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=f2p_catalog
