# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@db:5432/f2p_catalog

# Clave secreta de Flask (cambiar en producción)
SECRET_KEY=change-me-to-a-random-secret-key

# Entorno de Flask
FLASK_ENV=development

# URL base de la API FreeToGame
FREETOGAME_API_URL=https://www.freetogame.com/api

# Credenciales del usuario admin
ADMIN_EMAIL=admin@f2pcatalog.com
ADMIN_PASSWORD=admin1234

# Credenciales de PostgreSQL (usadas por docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=f2p_catalog
